HOST=0.0.0.0
PORT=3000
LOG_FORMAT=pretty
LOG_COLORS=true

JOB_INTERVAL_MS=300000
MAX_MESSAGES_PER_RUN=10
RUN_JOB_ON_STARTUP=false
ARCHIVE_AFTER_SUCCESS=true

DOCUMENT_PROCESSOR_MODE=mock-external
EXTERNAL_TRANSFORM_API_URL=
EXTERNAL_TRANSFORM_API_KEY=

GMAIL_INPUT_LABEL=SDG/Process
GMAIL_PROCESSING_LABEL=SDG/Processing
GMAIL_PROCESSED_LABEL=SDG/Processed
GMAIL_FAILED_LABEL=SDG/Failed

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GOOGLE_TOKEN_STORAGE_PATH=.tokens/google-oauth.json
GOOGLE_DRIVE_DESTINATION_FOLDER_ID=
