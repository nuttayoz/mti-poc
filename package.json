{
  "name": "smart-document-gateway",
  "version": "0.1.0",
  "description": "A NestJS and Bun service that routes Gmail attachments into processed Google Drive documents.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc --watch -p tsconfig.build.json",
    "start": "bun dist/main.js",
    "start:dev": "bun --watch dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/schedule": "6.1.3",
    "googleapis": "171.4.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "typescript": "6.0.3"
  }
}
